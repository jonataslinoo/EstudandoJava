<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/constraint_layout_cadastrar_produto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <include
        android:id="@+id/toolbar"
        layout="@layout/toolbar" />

    <EditText
        android:id="@+id/et_nome_cadastrar_produto"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="30dp"
        android:layout_marginTop="180dp"
        android:layout_marginEnd="30dp"
        android:hint="@string/nome_produto"
        android:importantForAutofill="no"
        android:inputType="text"
        android:textAllCaps="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/et_tipo_cadastrar_produto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:digits="mfMF"
        android:hint="@string/tipo_sexo"
        android:importantForAutofill="no"
        android:inputType="text"
        android:maxLength="1"
        app:layout_constraintStart_toStartOf="@+id/et_nome_cadastrar_produto"
        app:layout_constraintTop_toBottomOf="@+id/et_nome_cadastrar_produto" />

    <EditText
        android:id="@+id/et_preco_cadastrar_produto"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:hint="@string/preco_produto"
        android:importantForAutofill="no"
        android:inputType="numberDecimal"
        app:layout_constraintEnd_toEndOf="@+id/et_nome_cadastrar_produto"
        app:layout_constraintStart_toEndOf="@+id/et_tipo_cadastrar_produto"
        app:layout_constraintTop_toTopOf="@+id/et_tipo_cadastrar_produto" />

    <CheckBox
        android:id="@+id/checkBox_kit_cadastrar_produto"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/kit"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="@+id/et_preco_cadastrar_produto"
        app:layout_constraintStart_toStartOf="@+id/et_tipo_cadastrar_produto"
        app:layout_constraintTop_toBottomOf="@+id/et_preco_cadastrar_produto" />

    <Button
        android:id="@+id/bt_cadastrar_cadastrar_produto"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@drawable/botao_redondo_gradiente_roxo"
        android:text="@string/cadastrar"
        android:textColor="@color/corBranca"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="@+id/checkBox_kit_cadastrar_produto"
        app:layout_constraintStart_toStartOf="@+id/checkBox_kit_cadastrar_produto"
        app:layout_constraintTop_toBottomOf="@+id/checkBox_kit_cadastrar_produto" />

</androidx.constraintlayout.widget.ConstraintLayout>